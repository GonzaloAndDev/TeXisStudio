{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability — standard permissions for the desktop app.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-set-size",
    "dialog:default",
    "log:default"
