{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "TeXisStudio: Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash ${workspaceFolder}/scripts/bootstrap.sh run",
      "windows": {
        "command": "powershell -ExecutionPolicy Bypass -File ${workspaceFolder}\\scripts\\bootstrap-windows.ps1 -Run"
      },
      "presentation": {
        "group": "texis",
        "order": 1
      }
    },
    {
      "name": "TeXisStudio: Build",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash ${workspaceFolder}/scripts/bootstrap.sh installer",
      "windows": {
        "command": "powershell -ExecutionPolicy Bypass -File ${workspaceFolder}\\scripts\\bootstrap-windows.ps1 -Installer"
      },
      "presentation": {
        "group": "texis",
        "order": 2
      }
    },
    {
      "name": "TeXisStudio: Frontend only",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash ${workspaceFolder}/scripts/bootstrap.sh frontend-build",
      "windows": {
        "command": "powershell -ExecutionPolicy Bypass -File ${workspaceFolder}\\scripts\\bootstrap-windows.ps1 -FrontendBuild"
      },
      "presentation": {
        "group": "texis",
        "order": 3
      }
    }
  ]
}
