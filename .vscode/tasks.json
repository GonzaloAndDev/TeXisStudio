{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TeXisStudio: Run app",
      "type": "shell",
      "command": "node",
      "args": ["${workspaceFolder}/scripts/texis.mjs", "dev"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "TeXisStudio: Build current OS",
      "type": "shell",
      "command": "node",
      "args": ["${workspaceFolder}/scripts/texis.mjs", "build"],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "TeXisStudio: Frontend only",
      "type": "shell",
      "command": "node",
      "args": ["${workspaceFolder}/scripts/texis.mjs", "frontend-build"],
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
