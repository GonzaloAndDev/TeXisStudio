# Normalize all text files to LF in the repository
* text=auto eol=lf

# Explicitly text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.rs    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sh    text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary
